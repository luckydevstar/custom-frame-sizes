# Store A Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# ============================================
# Site Configuration
# ============================================
NEXT_PUBLIC_SITE_ID=store-a

# Google Tag Manager (optional). If unset, defaults to GTM-WNC3937K in app/layout.
# NEXT_PUBLIC_GTM_ID=GTM-WNC3937K

# ============================================
# Shopify Storefront API (Public - Client-side)
# ============================================
# Get these from your Shopify admin: Settings > Apps and sales channels > Develop apps

# Your Shopify store domain (e.g., "your-store.myshopify.com")
# Leave empty to use mock mode
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=

# Storefront API access token
# Create this in: Settings > Apps and sales channels > Develop apps > [Your App] > Storefront API
# Leave empty to use mock mode
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# Shopify API version (default: 2024-01)
NEXT_PUBLIC_SHOPIFY_API_VERSION=2024-01

# ============================================
# Product Variant IDs (Optional)
# ============================================
# Default variant ID for custom frames (if using single product for all frames)
NEXT_PUBLIC_SHOPIFY_FRAME_VARIANT_ID=

# Variant ID for mat boards (if selling mats separately)
NEXT_PUBLIC_SHOPIFY_MAT_VARIANT_ID=

# ============================================
# API Endpoints
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ============================================
# Asset source: Local vs Cloudflare R2 (see docs/ASSET_SOURCE.md)
# ============================================
# LOCAL: leave both empty → assets served from app /api/asset or public/
# CLOUDFLARE R2: set both to your R2 public bucket URLs (no trailing slash)
#
# Frame images (e.g. /frames/10727/10727-pro-a.jpg) are served from the store-a
# bucket. If you see 404s for corner/profile images, set NEXT_PUBLIC_CDN_STORE_A_URL
# to your store-a R2 bucket URL so the app returns full CDN URLs and the browser
# loads from R2.
#
# Example – Local (default):
#   NEXT_PUBLIC_CDN_SHARED_URL=
#   NEXT_PUBLIC_CDN_STORE_A_URL=
#
# Example – Cloudflare R2 (shared + store-a buckets):
#   NEXT_PUBLIC_CDN_SHARED_URL=https://pub-69a10dc9071244a289ce236ece9aba93.r2.dev
#   NEXT_PUBLIC_CDN_STORE_A_URL=https://pub-90cb5b0e26db4cc1b1ece8a4852edfc8.r2.dev
#
NEXT_PUBLIC_CDN_SHARED_URL=
NEXT_PUBLIC_CDN_STORE_A_URL=

# Optional: full path to assets_to_use (override auto-detection)
# LOCAL_ASSETS_ROOT=

# ============================================
# Sentry Error Tracking (Optional)
# ============================================
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_RELEASE=

# ============================================
# Order fulfillment (server-only — /api/order-files, /order-fulfillment)
# ============================================
# Store domain for Admin API (same as your .myshopify.com host)
# SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
#
# Option A — OAuth client_credentials (token auto-refreshed in memory; ~24h expiry)
# SHOPIFY_CLIENT_ID=
# SHOPIFY_CLIENT_SECRET=
#
# Option B — Static Admin token (manual rotation)
# SHOPIFY_ADMIN_ACCESS_TOKEN=
#
# If SHOPIFY_CLIENT_ID + SHOPIFY_CLIENT_SECRET are set, they take precedence over SHOPIFY_ADMIN_ACCESS_TOKEN.
# SHOPIFY_API_VERSION=2024-01
# FULFILLMENT_DASHBOARD_SECRET=

# ============================================
# Node Environment
# ============================================
NODE_ENV=development

