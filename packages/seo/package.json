{
  "name": "@framecraft/seo",
  "version": "0.1.0",
  "private": true,
  "description": "Brand-aware SEO helpers for FrameCraft storefronts (metadata, JSON-LD schemas, sitemap/robots/manifest builders)",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schemas": {
      "types": "./src/schemas/index.ts",
      "default": "./src/schemas/index.ts"
    },
    "./routes": {
      "types": "./src/routes/index.ts",
      "default": "./src/routes/index.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@framecraft/config": "*",
    "@framecraft/types": "*"
  },
  "peerDependencies": {
    "next": "^14.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "next": "^14.2.0",
    "typescript": "^5.6.3"
  },
  "keywords": [
    "framecraft",
    "seo",
    "metadata",
    "schema-org",
    "sitemap"
  ],
  "author": "FrameCraft Team",
  "license": "MIT"
}
